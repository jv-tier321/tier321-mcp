# Cloudflare credentials for deploying your own instance of tier321-mcp.
# Copy this file to .env and fill in real values — .env is gitignored.
#
# Both values are found in the Cloudflare dashboard:
#   https://dash.cloudflare.com/profile/api-tokens
#   https://dash.cloudflare.com/  (account ID in the right-hand sidebar)
#
# The CI/CD workflows in this repo do NOT consume these — CI runs tests
# and a wrangler --dry-run with no Cloudflare account. Secrets are only
# needed on your workstation for manual `npx wrangler deploy`.

# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
